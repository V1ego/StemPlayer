{
  "name": "stem-player",
  "version": "1.1.0",
  "description": "绫波分轨 — 灵感源于 Kanye STEM PLAYER × 绫波丽。AI 分离人声/鼓/贝斯/其他四轨，生成艺术可视化。",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.stemplayer.app",
    "productName": "ilya",
    "asar": false,
    "directories": {
      "output": "build-out"
    },
    "files": [
      "electron/**/*",
      "static/**/*",
      "app/**/*.py",
      "netease_proxy.js",
      "run.py",
      "requirements.txt",
      "node_modules/**/*",
      "!**/__pycache__/**",
      "!**/.git/**"
    ],
    "extraResources": [
      {
        "from": ".venv",
        "to": "python",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/pip/**",
          "!**/cache/**",
          "!**/_cache/**"
        ]
      },
      {
        "from": "../.ffmpeg",
        "to": ".ffmpeg",
        "filter": [
          "**/*",
          "!**/doc/**",
          "!**/include/**",
          "!**/presets/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "static/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "ilya-${version}.exe"
    }
  },
  "keywords": [
    "music",
    "stem",
    "demucs",
    "ai",
    "player"
  ],
  "author": "OuJia",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "NeteaseCloudMusicApi": "^4.27.0"
  }
}
